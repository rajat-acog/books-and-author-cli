---
import "../styles/global.css";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-slate-50">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Explore curated books and author profiles with BookHub."
    />
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <div class="min-h-screen flex flex-col">
      <header class="bg-white border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-16">
            <a
              href="/"
              class="text-2xl font-semibold tracking-tight text-slate-900"
            >
              BookHub
            </a>
            <nav
              class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-700"
            >
              <a href="/" class="hover:text-slate-900 transition">Home</a>
              <a href="/authors" class="hover:text-slate-900 transition"
                >Authors</a
              >
              <a href="/books" class="hover:text-slate-900 transition">Books</a>
            </nav>
          </div>
        </div>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer class="bg-slate-100 text-slate-600 py-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div
            class="flex flex-col gap-3 text-center md:flex-row md:items-center md:justify-between"
          >
            <p>© 2026 BookHub. Crafted for readers and literary lovers.</p>
            <p class="text-sm text-slate-500">
              Professional book and author showcase built with Astro.
            </p>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
