---
interface Props {
  id: string;
  name: string;
  bio: string;
}

const { id, name, bio } = Astro.props;
---

<a href={`/authors/${id}`} class="block group">
  <article
    class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md h-full flex flex-col"
  >
    <div class="p-8 flex flex-col items-center text-center">
      <div
        class="mb-6 flex h-20 w-20 items-center justify-center rounded-3xl bg-gradient-to-br from-indigo-500 to-purple-500 text-white"
      >
        <span class="text-2xl font-semibold"
          >{
            name
              .split(" ")
              .map((word) => word[0])
              .join("")
              .toUpperCase()
          }</span
        >
      </div>
      <h3 class="text-xl font-semibold text-slate-900">{name}</h3>
      <p class="mt-4 text-sm leading-6 text-slate-600 line-clamp-3">{bio}</p>
      <span
        class="mt-6 text-sm font-semibold text-slate-900 group-hover:text-slate-700"
        >View Profile →</span
      >
    </div>
  </article>
</a>
