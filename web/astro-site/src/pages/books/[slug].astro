---
import Layout from "../../layouts/Layout.astro";
import BookCard from "../../components/BookCard.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  const allBooks = authors.flatMap((author) =>
    author.data.books.map((book) => ({
      ...book,
      author: author.data.name,
      authorSlug: author.id,
      id: book.title.toLowerCase().replace(/[^a-z0-9]+/g, "-"),
    })),
  );

  return allBooks.map((book) => ({
    params: {
      slug: book.id,
    },
  }));
}

const { slug } = Astro.params;

const authors = await getCollection("authors");
const allBooks = authors.flatMap((author) =>
  author.data.books.map((book) => ({
    ...book,
    author: author.data.name,
    authorSlug: author.id,
    id: book.title.toLowerCase().replace(/[^a-z0-9]+/g, "-"),
  })),
);

const book = allBooks.find((b) => b.id === slug);

if (!book) {
  throw new Error("Book not found");
}

const relatedBooks = allBooks
  .filter((b) => b.author === book.author && b.id !== book.id)
  .slice(0, 3);
---

<Layout title={`${book.title} - BookHub`}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Book Cover and Details -->
      <div class="md:col-span-2">
        <div
          class="rounded-3xl border border-slate-200 bg-white shadow-sm overflow-hidden"
        >
          <div class="grid md:grid-cols-[1fr_1.5fr]">
            <!-- Cover -->
            <div class="bg-slate-100 p-8 flex items-center justify-center">
              {
                book.coverUrl ? (
                  <img
                    src={book.coverUrl}
                    alt={book.title}
                    class="max-w-full max-h-96 object-contain rounded-lg"
                  />
                ) : (
                  <div class="w-48 h-72 bg-slate-300 rounded-lg flex items-center justify-center">
                    <span class="text-slate-500 text-center px-4 text-sm">
                      No Cover Available
                    </span>
                  </div>
                )
              }
            </div>

            <!-- Details -->
            <div class="p-8 flex flex-col justify-between">
              <div>
                <h1 class="text-3xl font-semibold text-slate-900 mb-2">
                  {book.title}
                </h1>
                <p class="text-base text-slate-600 mb-6">
                  <span class="font-semibold text-slate-900">by </span>
                  <a
                    href={`/authors/${book.author.toLowerCase().replace(/\s+/g, "-")}`}
                    class="text-slate-900 font-semibold hover:text-slate-700 underline"
                  >
                    {book.author}
                  </a>
                </p>
                {
                  book.year && (
                    <p class="text-sm text-slate-600 mb-6">
                      <span class="font-semibold text-slate-900">
                        Published:
                      </span>{" "}
                      {book.year}
                    </p>
                  )
                }
                <div class="border-t border-slate-200 pt-6 mt-6">
                  <h2 class="text-lg font-semibold text-slate-900 mb-4">
                    Summary
                  </h2>
                  <p class="text-base leading-relaxed text-slate-700">
                    {book.summary}
                  </p>
                </div>
              </div>

              <!-- Action Buttons -->
              <div class="mt-8">
                <a
                  href="/books"
                  class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50"
                >
                  Back to Books
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div>
        <div
          class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sticky top-24"
        >
          <h3 class="text-lg font-semibold text-slate-900 mb-4">
            Book Details
          </h3>
          <div class="space-y-4 text-sm">
            <div>
              <p class="text-slate-600 font-medium mb-1">Title</p>
              <p class="text-slate-900">{book.title}</p>
            </div>
            <div>
              <p class="text-slate-600 font-medium mb-1">Author</p>
              <p class="text-slate-900">
                <a
                  href={`/authors/${book.author.toLowerCase().replace(/\s+/g, "-")}`}
                  class="hover:underline"
                >
                  {book.author}
                </a>
              </p>
            </div>
            {
              book.year && (
                <div>
                  <p class="text-slate-600 font-medium mb-1">Published</p>
                  <p class="text-slate-900">{book.year}</p>
                </div>
              )
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Related Books Section -->
    {
      relatedBooks.length > 0 && (
        <div class="mt-16 pt-12 border-t border-slate-200">
          <h2 class="text-3xl font-semibold text-slate-900 mb-8">
            More Books by {book.author}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {relatedBooks.map((relBook) => (
              <BookCard
                id={relBook.id}
                title={relBook.title}
                author={relBook.author}
                coverUrl={relBook.coverUrl}
                year={relBook.year}
                summary={relBook.summary}
              />
            ))}
          </div>
        </div>
      )
    }
  </div>
</Layout>
