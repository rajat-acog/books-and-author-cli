---
import Layout from "../layouts/Layout.astro";
import BookCard from "../components/BookCard.astro";
import AuthorCard from "../components/AuthorCard.astro";
import { getCollection } from "astro:content";

const authors = await getCollection("authors");

const books = authors.flatMap((author) =>
  author.data.books.map((book) => ({
    ...book,
    author: author.data.name,
    authorSlug: author.id,
  })),
);

const featuredAuthors = authors.slice(0, 3);
const featuredBooks = books.slice(0, 6);
---

<Layout title="BookHub — Discover Books & Authors">
  <section class="bg-slate-50 pt-16 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[1.5fr_1fr] lg:items-center">
        <div class="space-y-8">
          <div
            class="inline-flex rounded-full bg-indigo-50 px-4 py-1 text-sm font-semibold text-indigo-700 ring-1 ring-indigo-100"
          >
            Curated literary collection
          </div>
          <div class="space-y-4">
            <h1
              class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl"
            >
              Discover beautifully designed book and author profiles.
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-slate-600">
              BookHub makes it effortless to explore your next read with
              polished, reader-first pages that feel both modern and timeless.
            </p>
          </div>
          <div class="flex flex-wrap gap-4">
            <a
              href="/books"
              class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50 hover:text-slate-950"
            >
              Explore Books
            </a>
            <a
              href="/authors"
              class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50 hover:text-slate-950"
            >
              Explore Authors
            </a>
          </div>
        </div>

        <div
          class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm"
        >
          <div class="grid gap-6">
            <div class="rounded-3xl bg-slate-50 p-6">
              <p class="text-sm uppercase tracking-[0.24em] text-slate-500">
                Books
              </p>
              <p class="mt-3 text-4xl font-semibold text-slate-900">
                {books.length}
              </p>
              <p class="mt-2 text-sm text-slate-600">
                Thoughtfully selected titles.
              </p>
            </div>
            <div class="rounded-3xl bg-slate-50 p-6">
              <p class="text-sm uppercase tracking-[0.24em] text-slate-500">
                Authors
              </p>
              <p class="mt-3 text-4xl font-semibold text-slate-900">
                {authors.length}
              </p>
              <p class="mt-2 text-sm text-slate-600">
                Profiles with literary depth.
              </p>
            </div>
            <div class="rounded-3xl bg-slate-50 p-6">
              <p class="text-sm uppercase tracking-[0.24em] text-slate-500">
                Experience
              </p>
              <p class="mt-3 text-4xl font-semibold text-slate-900">
                Modern & Readable
              </p>
              <p class="mt-2 text-sm text-slate-600">
                Clear layouts for focused browsing.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm uppercase tracking-[0.24em] text-indigo-600">
          Meet the authors
        </p>
        <h2 class="mt-4 text-3xl font-semibold text-slate-900 sm:text-4xl">
          Featured Author Profiles
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-600">
          Browse compelling author voices from the collection.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          featuredAuthors.map((author) => (
            <AuthorCard
              id={author.id}
              name={author.data.name}
              bio={author.data.bio}
            />
          ))
        }
      </div>

      <div class="mt-10 text-center">
        <a
          href="/authors"
          class="text-indigo-600 font-semibold hover:text-indigo-700"
          >View all authors</a
        >
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm uppercase tracking-[0.24em] text-indigo-600">
          Explore books
        </p>
        <h2 class="mt-4 text-3xl font-semibold text-slate-900 sm:text-4xl">
          Featured Reads
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-600">
          A selection of polished titles to begin your next journey.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          featuredBooks.map((book) => (
            <BookCard
              id={book.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}
              title={book.title}
              author={book.author}
              coverUrl={book.coverUrl}
              year={book.year}
              summary={book.summary}
            />
          ))
        }
      </div>

      <div class="mt-10 text-center">
        <a
          href="/books"
          class="text-indigo-600 font-semibold hover:text-indigo-700"
          >View all books</a
        >
      </div>
    </div>
  </section>
</Layout>
